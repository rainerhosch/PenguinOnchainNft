    "@matterlabs/hardhat-zksync-telemetry": "^1.1.1",
    "@matterlabs/hardhat-zksync-upgradable": "^1.10.0",
    "@matterlabs/hardhat-zksync-verify": "^1.9.0",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.8",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.8",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.12",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.12",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@openzeppelin/contracts": "^4.7.2",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/bn.js": "^5.2.0",
